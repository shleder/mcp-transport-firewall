# Директория SQLite-кэша
CACHE_DIR=.mcp-cache

# TTL кэша в секундах (3600 = 1 час)
CACHE_TTL_SECONDS=3600

# Максимальное количество записей в in-memory LRU кэше
L1_MAX_ITEMS=500

# Максимальный размер ответа в байтах (5 МБ)
MAX_RESPONSE_BYTES=5242880

# Включить подробное логирование (true/false)
VERBOSE=false
