{
  "name": "mcp-transport-firewall",
  "version": "2.1.1",
  "description": "CLI firewall for fail-closed MCP stdio traffic",
  "main": "dist/cli.js",
  "bin": {
    "mcp-transport-firewall": "dist/cli.js"
  },
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:cli": "node dist/cli.js",
    "dev": "tsx watch src/index.ts",
    "dev:cli": "tsx src/cli.ts",
    "demo:stdio": "node scripts/stdio-demo.mjs",
    "benchmark:stdio": "npm run build && node scripts/stdio-benchmark.mjs",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "typecheck": "tsc --noEmit",
    "verify:all": "npm run typecheck && npm run build && npm test && npm run demo:stdio && npm --prefix ui run build && npm --prefix ui run lint"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1",
    "dotenv": "^17.3.1",
    "express": "^4.21.1",
    "lru-cache": "^11.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.8.2",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
