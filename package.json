{
  "name": "mcp-transport-firewall",
  "version": "2.1.1",
  "description": "Fail-closed stdio transport firewall for MCP JSON-RPC traffic and agent tool supply chains",
  "main": "dist/cli.js",
  "files": [
    "dist",
    "docs",
    ".env.example",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "SUPPORT.md"
  ],
  "bin": {
    "mcp-transport-firewall": "dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maksboreichuk88-commits/mcp-transport-firewall.git"
  },
  "bugs": {
    "url": "https://github.com/maksboreichuk88-commits/mcp-transport-firewall/issues"
  },
  "homepage": "https://github.com/maksboreichuk88-commits/mcp-transport-firewall#readme",
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "security",
    "firewall",
    "stdio",
    "json-rpc",
    "shadowleak",
    "trust-gates",
    "supply-chain-security",
    "defensive-security"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:cli": "node dist/cli.js",
    "dev": "tsx watch src/index.ts",
    "dev:cli": "tsx src/cli.ts",
    "demo:stdio": "node scripts/stdio-demo.mjs",
    "benchmark:stdio": "npm run build && node scripts/stdio-benchmark.mjs",
    "pack:dry-run": "npm pack --dry-run",
    "pack:smoke": "node scripts/pack-smoke.mjs",
    "prepublishOnly": "npm run verify:all && npm run pack:dry-run && npm run pack:smoke",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "typecheck": "tsc --noEmit",
    "verify:all": "npm run typecheck && npm run build && npm test && npm run demo:stdio && npm --prefix ui run build && npm --prefix ui run lint"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.3.1",
    "express": "^4.21.1",
    "lru-cache": "^11.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.8.2",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
