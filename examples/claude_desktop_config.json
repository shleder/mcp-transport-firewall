{
  "mcpServers": {
    "filesystem-optimized": {
      "command": "node",
      "args": [
        "/absolute/path/to/mcp-optimizer/dist/index.js",
        "--config", "/absolute/path/to/mcp-optimizer/mcp-optimizer.json",
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/yourname/projects"
      ],
      "env": {
        "ADMIN_TOKEN": "change-me-to-a-secret"
      }
    },
    "github-optimized": {
      "command": "node",
      "args": [
        "/absolute/path/to/mcp-optimizer/dist/index.js",
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "ghp_your_token_here",
        "MCP_CACHE_TTL_SECONDS": "300"
      }
    }
  }
}
